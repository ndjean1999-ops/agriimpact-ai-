# ============================================
# AGRIIMPACT AI — Variables d'environnement
# Copie ce fichier en ".env" et remplis les valeurs
# NE JAMAIS committer le fichier ".env" sur GitHub
# ============================================

# Port du serveur (Render/Railway le définissent automatiquement, sinon 3000 en local)
PORT=3000

# Clé secrète pour signer les tokens JWT (génère une chaîne aléatoire longue)
# Tu peux en générer une ici: https://generate-secret.vercel.app/32
JWT_SECRET=change-moi-en-une-chaine-aleatoire-longue-et-secrete

# Clé API Anthropic (Claude) — pour le diagnostic photo et le conseiller IA
# Obtenir sur https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx

# ============================================
# WHATSAPP CLOUD API (Meta)
# Obtenus sur https://developers.facebook.com
# ============================================

# Token d'accès permanent (System User Token) généré dans Meta Business Suite
WHATSAPP_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Phone Number ID — trouvé dans App Dashboard > WhatsApp > Configuration
WHATSAPP_PHONE_NUMBER_ID=xxxxxxxxxxxxxxxxx

# WhatsApp Business Account ID (WABA ID)
WHATSAPP_BUSINESS_ACCOUNT_ID=xxxxxxxxxxxxxxxxx

# Token de vérification du webhook — choisis une chaîne toi-même (ex: agriimpact2026)
# Tu la remettras dans la config du webhook sur Meta for Developers
WHATSAPP_VERIFY_TOKEN=agriimpact2026

# ============================================
# BASE DE DONNÉES
# ============================================
# Chemin du fichier SQLite (laisser tel quel pour commencer)
DATABASE_PATH=./data/agriimpact.db

# ============================================
# COMPTE MANAGER (toi, propriétaire de la plateforme)
# Utilisé une seule fois par "npm run create-manager"
# pour créer ton accès au panneau /manager
# ============================================
MANAGER_EMAIL=toi@example.com
MANAGER_PASSWORD=change-moi-mot-de-passe-fort-8-caracteres-minimum
MANAGER_NAME=Jean Dabouli
